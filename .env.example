###############################################################################
# Application
###############################################################################

APP_NAME=Laravel # The application name used in notifications, mail, and the UI.
APP_ENV=local # Environment name (common: local, staging, production). Docs: https://laravel.com/docs/13.x/configuration#environment-configuration
APP_KEY= # App encryption key. Generate with: php artisan key:generate Docs: https://laravel.com/docs/13.x/encryption
APP_DEBUG=true # Debug mode controls error verbosity. Never enable in production. Docs: https://laravel.com/docs/13.x/configuration#debug-mode
APP_URL=http://localhost # Base URL used when generating absolute links (emails, redirects, assets). Docs: https://laravel.com/docs/13.x/helpers#method-url
# APP_TIMEZONE=UTC # Optional: timezone used by PHP/Laravel. Docs: https://laravel.com/docs/13.x/configuration#timezone
APP_LOCALE=en # Locale used by the framework for translations. Docs: https://laravel.com/docs/13.x/localization
APP_FALLBACK_LOCALE=en # Locale used when a translation key is missing. Docs: https://laravel.com/docs/13.x/localization
APP_FAKER_LOCALE=en_US # Locale used by Faker when seeding/testing. Docs: https://laravel.com/docs/13.x/database-testing
APP_MAINTENANCE_DRIVER=file # Maintenance mode driver. Docs: https://laravel.com/docs/13.x/configuration#maintenance-mode
# APP_MAINTENANCE_STORE=database # Store used by the maintenance driver, when applicable. Docs: https://laravel.com/docs/13.x/configuration#maintenance-mode
# PHP_CLI_SERVER_WORKERS=4 # Optional: workers for `php artisan serve`. Docs: https://www.php.net/manual/en/features.commandline.webserver.php
BCRYPT_ROUNDS=12 # Password hashing work factor (higher = slower = more secure). Docs: https://laravel.com/docs/13.x/hashing

###############################################################################
# Logging
###############################################################################

LOG_CHANNEL=stack # Primary log channel.
LOG_STACK=single # Channels included in the "stack" channel.
LOG_DEPRECATIONS_CHANNEL=null # Where PHP deprecation warnings are logged (null to disable).
LOG_LEVEL=debug # Log verbosity (debug/info/warning/error). Docs: https://laravel.com/docs/13.x/logging

###############################################################################
# Database
###############################################################################

DB_CONNECTION=pgsql # Connection name (common: sqlite, mysql, pgsql).
DB_HOST=db # Hostname (in Docker/Sail, usually the service name). Docs: https://laravel.com/docs/13.x/database
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
# DB_SSLMODE=require # Optional: PostgreSQL SSL mode if your platform requires it. Docs: https://www.postgresql.org/docs/current/libpq-ssl.html

###############################################################################
# Sessions / Cookies
###############################################################################

SESSION_DRIVER=database # Where session data is stored (common: file, database, redis).
SESSION_LIFETIME=120 # Session lifetime in minutes.
SESSION_ENCRYPT=false # Encrypt the session payload (adds overhead; can be useful for extra defense).
SESSION_PATH=/ # URL path scope for the session cookie (`path` in config/session.php). Docs: https://laravel.com/docs/13.x/session#configuration
SESSION_DOMAIN=null # Cookie domain. Use a real domain for local subdomains (e.g. ".test").
# SESSION_SECURE_COOKIE=true # Optional: only send session cookies over HTTPS. Docs: https://laravel.com/docs/13.x/session
# SESSION_SAME_SITE=lax # Optional: cookie SameSite policy (lax/strict/none). Docs: https://laravel.com/docs/13.x/session

###############################################################################
# Cache / Queue / Files / Broadcast
###############################################################################

BROADCAST_CONNECTION=log # Broadcast driver (log is safe for local; redis/pusher for realtime). Docs: https://laravel.com/docs/13.x/broadcasting
FILESYSTEM_DISK=local # Default filesystem disk (local/s3/etc). Docs: https://laravel.com/docs/13.x/filesystem
QUEUE_CONNECTION=database # Queue connection (database is easy to run locally; redis is common at scale). Docs: https://laravel.com/docs/13.x/queues
CACHE_STORE=database # Cache store (database is convenient; redis is common at scale). Docs: https://laravel.com/docs/13.x/cache
# CACHE_PREFIX= # Optional: cache key prefix for multi-app shared cache. Docs: https://laravel.com/docs/13.x/cache
MEMCACHED_HOST=127.0.0.1 # Memcached host (only used if you switch cache/session to memcached). Docs: https://laravel.com/docs/13.x/cache

###############################################################################
# Redis
###############################################################################

REDIS_CLIENT=phpredis # Redis client library (phpredis is recommended). Docs: https://laravel.com/docs/13.x/redis
REDIS_HOST=redis # Hostname (in Docker/Sail, usually the service name). Docs: https://laravel.com/docs/13.x/redis
REDIS_PASSWORD=null
REDIS_PORT=6379

###############################################################################
# Mail
###############################################################################

MAIL_MAILER=smtp # Transport (smtp/ses/mailgun/postmark/log/array/etc). Docs: https://laravel.com/docs/13.x/mail
MAIL_SCHEME=null # Optional SMTP scheme (null means "let the driver decide"). Docs: https://laravel.com/docs/13.x/mail
MAIL_HOST=mailpit # SMTP host (Mailpit is a good local default). Docs: https://laravel.com/docs/13.x/mail
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null

# MAIL_ENCRYPTION=tls # Optional: encryption (tls/ssl) depending on provider. Docs: https://laravel.com/docs/13.x/mail

MAIL_FROM_ADDRESS="hello@example.com" # Default "from" address for outgoing emails.
MAIL_FROM_NAME="${APP_NAME}"

###############################################################################
# AWS / S3 (optional)
###############################################################################

AWS_ACCESS_KEY_ID= # Access key (leave blank for local / non-S3 setups). Docs: https://laravel.com/docs/13.x/filesystem#amazon-s3-compatible-filesystems
AWS_SECRET_ACCESS_KEY= # Secret key (leave blank for local / non-S3 setups). Docs: https://laravel.com/docs/13.x/filesystem#amazon-s3-compatible-filesystems
AWS_DEFAULT_REGION=us-east-1 # Default AWS region used by SDKs. Docs: https://laravel.com/docs/13.x/filesystem#amazon-s3-compatible-filesystems
AWS_BUCKET= # Bucket name when using S3. Docs: https://laravel.com/docs/13.x/filesystem#amazon-s3-compatible-filesystems
AWS_USE_PATH_STYLE_ENDPOINT=false # True for some S3-compatible providers. Docs: https://laravel.com/docs/13.x/filesystem#amazon-s3-compatible-filesystems

###############################################################################
# Frontend (Vite)
###############################################################################

VITE_APP_NAME="${APP_NAME}" # Available in JS via import.meta.env.VITE_APP_NAME. Docs: https://laravel.com/docs/13.x/vite#environment-variables

# VITE_DEV_SERVER_URL=http://localhost:5173 # Optional: Vite dev server URL if running separately. Docs: https://laravel.com/docs/13.x/vite
